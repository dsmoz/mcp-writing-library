# Qdrant Configuration
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# OpenAI Configuration (for embeddings)
OPENAI_API_KEY=your_openai_api_key_here
EMBEDDING_MODEL=text-embedding-3-small

# Collection Names
COLLECTION_PASSAGES=writing_passages
COLLECTION_TERMS=writing_terms

# Logging
LOG_LEVEL=INFO

# Plagiarism Check — External (Tavily)
TAVILY_API_KEY=


# Plagiarism Check — Thresholds (optional, these are the defaults)
PLAGIARISM_INTERNAL_THRESHOLD=0.85
PLAGIARISM_EXTERNAL_THRESHOLD=0.75
PLAGIARISM_VERDICT_THRESHOLD_PCT=30.0

# Error tracking (optional — set in Railway dashboard to enable Sentry)
SENTRY_DSN=

# HTTP Transport (Railway deployment)
# Set TRANSPORT=http to enable HTTP streaming mode (default: stdio)
TRANSPORT=stdio
# Railway injects PORT automatically — do not set manually in production
PORT=8000
# Comma-separated bearer tokens for API auth (required when TRANSPORT=http)
API_TOKENS=
# Public domain Railway assigns to the service (set after railway domain generate)
RAILWAY_PUBLIC_DOMAIN=

# Persistent volume for per-user pattern overrides (Railway volume mount)
# Falls back to data/patterns/users/ (gitignored) for local/stdio mode
PATTERNS_USER_DIR=/mnt/patterns/users
